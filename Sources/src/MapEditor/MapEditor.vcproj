			UseOfMFC="2"
			ATLMinimizesCRunTimeLibraryUsage="FALSE">
			<Tool
				Name="VCCLCompilerTool"
				AdditionalOptions="/I /Zm300 "
				Optimization="0"
				AdditionalIncludeDirectories="COI"
				PreprocessorDefinitions="__AFX__;_DO_ASSERT_SLOW;_DO_SEH;NDEBUG;_WINDOWS;WIN32;_DO_CHECKED_CAST"
				BasicRuntimeChecks="3"
				RuntimeLibrary="2"
				RuntimeTypeInfo="TRUE"
				UsePrecompiledHeader="3"
