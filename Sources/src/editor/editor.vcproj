				Name="VCCustomBuildTool"/>
			<Tool
				Name="VCLinkerTool"
				IgnoreImportLibrary="TRUE"
				AdditionalDependencies="version.lib winmm.lib comsupp.lib Shlwapi.lib"
				OutputFile="BetaRelease/reseditor.exe"
