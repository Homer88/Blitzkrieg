			OutputDirectory=".\BetaRelease"
			IntermediateDirectory=".\BetaRelease"
			ConfigurationType="1"
			UseOfMFC="2"
			ATLMinimizesCRunTimeLibraryUsage="FALSE">
			<Tool
				Name="VCCLCompilerTool"
				AdditionalOptions="/Zm200 "
				Optimization="0"
				GlobalOptimizations="TRUE"
				InlineFunctionExpansion="2"
				ImproveFloatingPointConsistency="TRUE"
				FavorSizeOrSpeed="1"
				AdditionalIncludeDirectories="COI"
				PreprocessorDefinitions="__AFX__;_DO_ASSERT_SLOW;_DO_SEH;_WINDOWS;WIN32;NDEBUG;_BETARELEASE"
				RuntimeLibrary="2"
				RuntimeTypeInfo="TRUE"
				UsePrecompiledHeader="3"
