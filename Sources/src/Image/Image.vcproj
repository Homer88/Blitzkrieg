			<Tool
				Name="VCCLCompilerTool"
				Optimization="0"
				PreprocessorDefinitions="_DO_ASSERT_SLOW;NDEBUG;_DONT_LOAD_SINGLETONS;_WINDOWS;WIN32;_DO_CHECKED_CAST"
